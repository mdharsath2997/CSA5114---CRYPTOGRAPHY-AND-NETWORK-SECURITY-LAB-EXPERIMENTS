#include <stdio.h>
#include <string.h>
#include <ctype.h>

char matrix[5][5] = {
    {'M','O','N','A','R'},
    {'C','H','Y','B','D'},
    {'E','F','G','I','K'},
    {'L','P','Q','S','T'},
    {'U','V','W','X','Z'}
};

void findPosition(char ch, int *row, int *col)
{
    if(ch == 'J')
        ch = 'I';

    for(int i = 0; i < 5; i++)
    {
        for(int j = 0; j < 5; j++)
        {
            if(matrix[i][j] == ch)
            {
                *row = i;
                *col = j;
                return;
            }
        }
    }
}

int main()
{
    char text[100];
    int r1, c1, r2, c2;

    printf("Enter two uppercase letters: ");
    scanf("%s", text);

    findPosition(text[0], &r1, &c1);
    findPosition(text[1], &r2, &c2);

    if(r1 == r2)
    {
        printf("Encrypted Text: %c%c\n",
               matrix[r1][(c1 + 1) % 5],
               matrix[r2][(c2 + 1) % 5]);
    }
    else if(c1 == c2)
    {
        printf("Encrypted Text: %c%c\n",
               matrix[(r1 + 1) % 5][c1],
               matrix[(r2 + 1) % 5][c2]);
    }
    else
    {
        printf("Encrypted Text: %c%c\n",
               matrix[r1][c2],
               matrix[r2][c1]);
    }

    return 0;
}

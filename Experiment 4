#include <stdio.h>
#include <string.h>
int main(){
    char text[100], key[100];
    int i, j, lenText, lenKey;
    printf("Enter the plaintext (UPPERCASE): ");
    scanf("%s", text);
    printf("Enter the key (UPPERCASE): ");
    scanf("%s", key);
    lenText = strlen(text);
    lenKey = strlen(key);
    for(i = 0, j = 0; i < lenText; i++, j++){
        if(j == lenKey)
            j = 0;
        text[i] = ((text[i] - 'A') + (key[j] - 'A')) % 26 + 'A';
    }
    printf("Encrypted Text: %s\n", text);
    return 0;
}
